# AlloLabs reads these values from the process environment.
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key

# Optional command-line overrides. The dashboard sets these automatically.
# ALLOLABS_TRAINING_YEARS=1
# ALLOLABS_OOS_YEARS=0.5
# ALLOLABS_MAX_POSITION_WEIGHT=0.15
# ALLOLABS_LONG_ONLY=true
# ALLOLABS_MAX_SECTOR_WEIGHT=0.35
# ALLOLABS_REGULARIZATION=none
# ALLOLABS_REGULARIZATION_STRENGTH=0.10
# ALLOLABS_GPT_VIEWS=false
# ALLOLABS_RESEARCH_PROVIDER=openai
# ALLOLABS_RESEARCH_MODEL=gpt-5.4
# ALLOLABS_GPT_AUDIT=false
# ALLOLABS_AUDIT_PROVIDER=openai
# ALLOLABS_GPT_AUDIT_MODEL=gpt-5.5
# ALLOLABS_GPT_AUDIT_MAX_OUTPUT_TOKENS=64000
# ALLOLABS_GPT_AUDIT_ATTEMPTS=3
# ALLOLABS_REFRESH_CACHE=false
# ALLOLABS_RESEARCH_TICKERS=["AAPL","MSFT","RY.TO"]
# ALLOLABS_REMOTE_TOKEN=replace_with_a_long_random_value
